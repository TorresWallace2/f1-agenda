generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String               @id @default(cuid())
  name          String?
  email         String?              @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  calendarLinks GoogleCalendarLink[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GoogleCalendarLink {
  id           String   @id @default(cuid())
  userId       String
  calendarId   String
  calendarName String   @default("Agenda F1 & F2")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

model Season {
  id        String   @id @default(cuid())
  year      Int      @unique
  createdAt DateTime @default(now())
  rounds    Round[]
}

model Circuit {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  locality    String?
  country     String
  countryCode String
  imageUrl    String?
  rounds      Round[]
}

model Round {
  id        String       @id @default(cuid())
  seasonId  String
  series    String
  round     Int
  slug      String
  name      String
  startDate DateTime
  endDate   DateTime
  circuitId String
  season    Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  circuit   Circuit      @relation(fields: [circuitId], references: [id])
  sessions  RaceSession[]
  results   RaceResult[]

  @@unique([seasonId, series, round])
}

model RaceSession {
  id            String        @id @default(cuid())
  roundId       String
  series        String
  name          String
  kind          String
  startsAtUtc   DateTime?
  endsAtUtc     DateTime?
  status        String @default("TBA")
  source        String
  externalId    String?
  googleEventId String?
  round         Round         @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([series, startsAtUtc])
}

model DriverStanding {
  id          String     @id @default(cuid())
  seasonYear  Int
  series      String
  position    Int
  driverName  String
  driverCode  String?
  nationality String?
  teamName    String?
  points      Float

  @@unique([seasonYear, series, position, driverName])
}

model TeamStanding {
  id         String     @id @default(cuid())
  seasonYear Int
  series     String
  position   Int
  teamName   String
  points     Float

  @@unique([seasonYear, series, position, teamName])
}

model RaceResult {
  id         String     @id @default(cuid())
  roundId    String
  series     String
  sessionKind String
  position   Int
  driverName String
  driverCode String?
  teamName   String?
  laps       Int?
  time       String?
  points     Float?
  status     String?
  round      Round      @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@index([series, sessionKind, position])
}
