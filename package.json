{
  "name": "agenda-f1-f2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "build:full": "prisma generate && next build",
    "render:build": "prisma generate && next build",
    "render:start": "prisma db push --skip-generate && next start -H 0.0.0.0 -p 10000",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "cross-env PRISMA_SCHEMA_ENGINE_BINARY=./node_modules/@prisma/engines/schema-engine-windows.exe prisma migrate dev",
    "prisma:push": "cross-env PRISMA_SCHEMA_ENGINE_BINARY=./node_modules/@prisma/engines/schema-engine-windows.exe prisma db push",
    "sync:data": "tsx scripts/sync-data.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.1.2",
    "date-fns": "^4.1.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.25.0",
    "next": "^16.2.11",
    "next-auth": "^4.24.15",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
